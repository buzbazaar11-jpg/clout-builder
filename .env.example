# Copy to .env.local for local development.
# Public (client) vars MUST be prefixed VITE_

VITE_APP_NAME="AYMO Digital"

# Lovable Cloud (auto-injected on Lovable). Only set locally if self-hosting.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only secrets (no VITE_ prefix). Read inside server functions only.
# LOVABLE_API_KEY=
